                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/b10"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@+id/box6"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/box3" />

            <TextView
                android:id="@+id/box5_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="อาคาร 10"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box5"
                app:layout_constraintEnd_toEndOf="@+id/box5"
                app:layout_constraintStart_toStartOf="@+id/box5" />

            <!-- Box 6 -->
            <ImageView
                android:id="@+id/box6"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:rotation="180"
                android:scaleType="fitCenter"
                android:src="@drawable/b15"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/box5"
                app:layout_constraintTop_toBottomOf="@+id/box4" />

            <TextView
                android:id="@+id/box6_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="อาคาร 15"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box6"
                app:layout_constraintEnd_toEndOf="@+id/box6"
                app:layout_constraintStart_toStartOf="@+id/box6" />

            <!-- Box 7 -->
            <ImageView
                android:id="@+id/box7"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:rotation="180"
                android:scaleType="fitCenter"
                android:src="@drawable/b21"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@+id/box8"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/box5" />

            <TextView
                android:id="@+id/box7_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="อาคาร 21"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box7"
                app:layout_constraintEnd_toEndOf="@+id/box7"
                app:layout_constraintStart_toStartOf="@+id/box7" />

            <!-- Box 8 -->
            <ImageView
                android:id="@+id/box8"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:rotation="180"
                android:scaleType="fitCenter"
                android:src="@drawable/b23"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/box7"
                app:layout_constraintTop_toBottomOf="@+id/box6" />

            <TextView
                android:id="@+id/box8_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="อาคาร 23"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box8"
                app:layout_constraintEnd_toEndOf="@+id/box8"
                app:layout_constraintStart_toStartOf="@+id/box8" />

            <!-- Box 9 -->
            <ImageView
                android:id="@+id/box9"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@+id/box10"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/box7" />

            <TextView
                android:id="@+id/box9_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="Pano 4"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box9"
                app:layout_constraintEnd_toEndOf="@+id/box9"
                app:layout_constraintStart_toStartOf="@+id/box9" />

            <!-- Box 10 -->
            <ImageView
                android:id="@+id/box10"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:background="@drawable/history_card_background"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/box9"
                app:layout_constraintTop_toBottomOf="@+id/box8" />

            <TextView
                android:id="@+id/box10_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:background="#80FFFFFF"
                android:paddingVertical="4dp"
                android:text="Pano 1"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/box10"
                app:layout_constraintEnd_toEndOf="@+id/box10"
                app:layout_constraintStart_toStartOf="@+id/box10" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <View
        android:id="@+id/nav_bar_background"
        android:layout_width="0dp"
        android:layout_height="77dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/rounded_white_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/homeBtn"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/home_button_background"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/home"
        android:translationY="-36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/nav_bar_background"
        app:tint="@android:color/holo_blue_dark" />

    <ImageButton
        android:id="@+id/aboutBtn"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/about"
        app:layout_constraintEnd_toStartOf="@+id/historyBtn"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="@+id/nav_bar_background"
        app:layout_constraintTop_toTopOf="@+id/nav_bar_background"
        app:tint="@android:color/darker_gray" />

    <ImageButton
        android:id="@+id/historyBtn"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/history"
        app:layout_constraintBottom_toBottomOf="@+id/nav_bar_background"
        app:layout_constraintEnd_toStartOf="@+id/homeBtn"
        app:layout_constraintStart_toEndOf="@+id/aboutBtn"
        app:layout_constraintTop_toTopOf="@+id/nav_bar_background"
        app:layout_constraintVertical_bias="0.428"
        app:tint="@android:color/darker_gray" />

    <ImageButton
        android:id="@+id/gmapBtn"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/gmap"
        app:layout_constraintBottom_toBottomOf="@+id/nav_bar_background"
        app:layout_constraintStart_toEndOf="@+id/homeBtn"
        app:layout_constraintTop_toTopOf="@+id/nav_bar_background"
        app:tint="@android:color/darker_gray" />

    <ImageButton
        android:id="@+id/settingBtn"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/setting"
        app:layout_constraintBottom_toBottomOf="@+id/nav_bar_background"
        app:layout_constraintEnd_toEndOf="@+id/nav_bar_background"
        app:layout_constraintStart_toEndOf="@+id/gmapBtn"
        app:layout_constraintTop_toTopOf="@+id/nav_bar_background"
        app:tint="@android:color/darker_gray" />

</androidx.constraintlayout.widget.ConstraintLayout>